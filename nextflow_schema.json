{
    "$schema": "https://json-schema.org/draft-07/schema",
    "$id": "https://raw.githubusercontent.com/chelauk/lp-wgs/main/nextflow_schema.json",
    "title": "fht/lp-wgs pipeline parameters",
    "description": "An open-source shallow whole genome sequence analysis",
    "type": "object",
    "definitions": {
        "input_output_options": {
            "title": "Input/output options",
            "type": "object",
            "fa_icon": "fas fa-terminal",
            "description": "Define where the pipeline should find input data and save output data.",
            "required": ["input", "outdir"],
            "properties": {
                "input": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "schema": "assets/schema_input.json",
                    "mimetype": "text/csv",
                    "pattern": "^\\S+\\.csv$",
                    "description": "Path to comma-separated file containing information about the samples in the experiment.",
                    "help_text": "You will need to create a design file with information about the samples in your experiment before running the pipeline. Use this parameter to specify its location. It has to be a comma-separated file with 3 columns, and a header row.",
                    "fa_icon": "fas fa-file-csv"
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.",
                    "fa_icon": "fas fa-folder-open",
                    "default": "results"
                }
            }
        },
        "generic_options": {
            "title": "Generic options",
            "type": "object",
            "fa_icon": "fas fa-file-import",
            "description": "Less common options for the pipeline, typically set in a config file.",
            "help_text": "These options are common to all nf-core pipelines and allow you to customise some of the core preferences for how the pipeline runs.\n\nTypically these options would be set in a Nextflow config file loaded for all pipeline runs, such as `~/.nextflow/config`.",
            "properties": {
                "version": {
                    "type": "boolean",
                    "description": "Display version and exit.",
                    "fa_icon": "fas fa-question-circle",
                    "hidden": true
                },
                "help": {
                    "type": "boolean",
                    "description": "Display help text and exit.",
                    "fa_icon": "fas fa-question-circle",
                    "hidden": true
                },
                "validate_params": {
                    "type": "boolean",
                    "description": "Boolean whether to validate parameters against the schema at runtime",
                    "default": true,
                    "fa_icon": "fas fa-check-square",
                    "hidden": true
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/definitions/input_output_options"
        },
        {
            "$ref": "#/definitions/generic_options"
        }
    ],
    "properties": {
        "tech": {
            "type": "string",
            "default": "illumina",
            "enum": ["illumina", "nanopore"]
        },
        "sort": {
            "type": "boolean",
            "default": true
        },
        "step": {
            "type": "string",
            "default": "mapping",
            "enum": ["mapping", "calling"]
        },
        "tools": {
            "type": "string",
            "default": "ace,ichor,ascat,bayes_cna",
            "pattern": "^[A-Za-z_,]+$",
            "description": "Comma-separated list of downstream calling tools to run."
        },
        "call_gc": {
            "type": "string"
        },
        "fastp_adapter_fasta": {
            "type": "string",
            "format": "file-path",
            "description": "Optional adapter FASTA passed to fastp --adapter_fasta."
        },
        "filter_bam": {
            "type": "boolean"
        },
        "filter_bam_min": {
            "type": "integer",
            "default": 90
        },
        "filter_bam_max": {
            "type": "integer",
            "default": 150
        },
        "ploidy": {
            "type": "integer",
            "default": 2
        },
        "ace_ploidy": {
            "type": ["string", "integer"],
            "default": "2,3,4",
            "description": "Comma-separated ploidy values passed to ACE, e.g. 2 or 2,3,4."
        },
        "ascat_pcf_gamma": {
            "type": "number",
            "default": 10,
            "exclusiveMinimum": 0,
            "description": "Penalty parameter passed to copynumber::pcf for ASCAT low-pass segmentation."
        },
        "bin": {
            "type": "integer",
            "default": 1000
        },
        "insertsizemetrics": {
            "type": "string"
        },
        "genome": {
            "type": "string",
            "default": "GATK.GRCh38"
        },
        "igenomes_ignore": {
            "type": "string"
        },
        "igenomes_base": {
            "type": "string"
        },
        "save_reference": {
            "type": "string"
        },
        "normal": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "ichor_cfDNA": {
            "type": "boolean",
            "default": false,
            "description": "Use low-fraction cfDNA ichorCNA defaults."
        },
        "ichor_purity_manual": {
            "type": "string"
        },
        "ichor_genome_build": {
            "type": ["string", "null"],
            "description": "Genome build label passed to ichorCNA. If unset, the pipeline derives it from the selected genome configuration."
        },
        "ichor_genome_style": {
            "type": ["string", "null"],
            "enum": ["UCSC", "NCBI", null],
            "description": "Chromosome naming style passed to ichorCNA. If unset, the pipeline derives it from the selected genome configuration."
        },
        "validationShowHiddenParams": {
            "type": "boolean",
            "default": true
        },
        "validationSchemaIgnoreParams": {
            "type": "boolean",
            "default": true
        },
        "seq_center": {
            "type": "string",
            "default": "FHT_GF"
        },
        "seq_platform": {
            "type": "string",
            "default": "ILLUMINA"
        },
        "library": {
            "type": "string",
            "default": "default"
        },
        "multiqc_config": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "multiqc_title": {
            "type": "string"
        },
        "multiqc_logo": {
            "type": "string"
        },
        "max_multiqc_email_size": {
            "type": "string",
            "default": "25.MB"
        },
        "multiqc_methods_description": {
            "type": "string"
        },
        "tracedir": {
            "type": "string",
            "default": "results/Reports/pipeline_info"
        },
        "publish_dir_mode": {
            "type": "string",
            "default": "copy"
        },
        "email": {
            "type": "string"
        },
        "email_on_fail": {
            "type": "string"
        },
        "plaintext_email": {
            "type": "boolean"
        },
        "monochrome_logs": {
            "type": "boolean"
        },
        "hook_url": {
            "type": "string"
        },
        "show_hidden_params": {
            "type": "boolean"
        },
        "schema_ignore_params": {
            "type": "string",
            "default": "genomes,trace_timestamp"
        },
        "trace_timestamp": {
            "type": "string",
            "description": "Timestamp used to name Nextflow trace, report, timeline, and DAG files.",
            "hidden": true
        },
        "dict": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "fasta": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "fasta_fai": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "bwa": {
            "type": ["string", "null"],
            "format": "directory-path",
            "exists": true
        },
        "centromere": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "map_wig": {
            "type": ["string", "null"],
            "format": "directory-path",
            "exists": true
        },
        "map_wig_file": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "gc_wig": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "mosdepth_bed": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "chr_bed": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "medicc_arms": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "medicc_genes": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "chr_arm_boundaries": {
            "type": ["string", "null"],
            "format": "file-path",
            "exists": true
        },
        "qdnaseq_genome": {
            "type": ["string", "null"],
            "enum": ["hg19", "hg38", "mm10", null]
        },
        "qdnaseq_package": {
            "type": ["string", "null"]
        },
        "hmmcopy_chromosomes": {
            "type": ["string", "null"]
        }
    }
}
